{
  "routes": [
    { "route": "/", "allowedRoles": ["admin"] },
    { "route": "/index.html", "allowedRoles": ["admin"] },
    { "route": "/upload.html", "allowedRoles": ["anonymous", "authenticated"] },
    { "route": "/display.html", "allowedRoles": ["anonymous", "authenticated"] }
  ],
  "responseOverrides": {
    "401": { "redirect": "/.auth/login/github", "statusCode": 302 }
  }
}